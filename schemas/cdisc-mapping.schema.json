{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/tauri-shinylive-harness/cdisc-mapping.schema.json",
  "title": "Synthetic Clinical Data To CDISC Bridge Mapping",
  "type": "object",
  "required": ["schemaVersion", "sourceSchema", "targetStandard", "domains"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "sourceSchema": {
      "type": "string",
      "const": "tauri-shinylive-harness.synthetic-clinical-v1"
    },
    "targetStandard": {
      "type": "object",
      "required": ["name", "version", "note"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "enum": ["SDTM bridge"]
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "note": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "domains": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["targetDomain", "columns"],
        "additionalProperties": false,
        "properties": {
          "targetDomain": {
            "type": "string",
            "minLength": 2
          },
          "columns": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
              "type": "object",
              "required": ["target", "relationship"],
              "additionalProperties": false,
              "properties": {
                "target": {
                  "type": "string",
                  "minLength": 1
                },
                "relationship": {
                  "type": "string",
                  "enum": ["direct", "derived", "controlled-term", "not-mapped"]
                },
                "notes": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
