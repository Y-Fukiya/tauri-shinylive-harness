{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/tauri-shinylive-harness/clinical-data-pack.schema.json",
  "title": "Clinical Demo Data Pack",
  "type": "object",
  "required": ["id", "version", "synthetic", "description", "domains", "primarySubject"],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "synthetic": {
      "const": true
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "domains": {
      "type": "array",
      "minItems": 7,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "demographics",
          "visits",
          "labs",
          "vitals",
          "adverse_events",
          "concomitant_meds",
          "exposure"
        ]
      }
    },
    "primarySubject": {
      "type": "string",
      "minLength": 1
    }
  }
}
