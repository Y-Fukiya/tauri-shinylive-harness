{
  "name": "tauri-shinylive-harness",
  "version": "0.9.1",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.3.0",
  "bin": {
    "tauri-shinylive-harness": "scripts/harness.mjs"
  },
  "scripts": {
    "harness": "node scripts/harness.mjs",
    "dev": "vite --host 127.0.0.1 --port 1420",
    "clean:dist": "node scripts/clean-dist.mjs",
    "clean:tauri-bundles": "node scripts/clean-tauri-bundles.mjs",
    "build:portal": "vite build",
    "prepare:dist": "node scripts/prepare-dist.mjs",
    "build:all": "npm run clean:dist && npm run build:portal && npm run prepare:dist",
    "check": "tsc --noEmit",
    "gate:fast": "npm run check && npm run test:unit && npm run validate:config && npm run validate:data && npm run guard:phi",
    "gate:bundle": "npm run gate:fast && npm run build:all && npm run verify:static && npm run audit:tauri-security && npm run verify:offline",
    "gate:dev": "npm run gate:bundle",
    "gate:release": "node scripts/release-gate.mjs",
    "gate:internal-release": "node scripts/release-gate.mjs --internal",
    "doctor": "node scripts/harness.mjs doctor",
    "doctor:tooling": "node scripts/release-doctor.mjs --scope tooling",
    "doctor:artifacts": "node scripts/release-doctor.mjs --scope artifacts",
    "doctor:release": "node scripts/release-doctor.mjs --scope all",
    "validate:config": "node scripts/harness.mjs validate-config",
    "validate:data": "node scripts/harness.mjs validate-data",
    "generate:data-packs": "node scripts/generate-clinical-demo-packs.mjs",
    "cache:shinylive-assets": "Rscript scripts/cache-shinylive-assets.R",
    "test:unit": "node --test scripts/*.test.mjs",
    "test:rust": "cargo test --manifest-path crates/harness-server/Cargo.toml",
    "audit:tauri-security": "node scripts/harness.mjs audit-tauri-security",
    "audit:reproducibility": "node scripts/harness.mjs reproducibility",
    "audit:reproducibility:strict": "node scripts/reproducibility-report.mjs --strict",
    "smoke:multi-app": "node scripts/multi-app-smoke.mjs",
    "verify": "node scripts/harness.mjs verify",
    "verify:static": "node scripts/harness.mjs verify-static",
    "verify:e2e": "node scripts/e2e-verify.mjs",
    "verify:offline": "node scripts/offline-verify.mjs",
    "verify:release": "node scripts/harness.mjs verify-release",
    "guard:phi": "node scripts/phi-pii-guard.mjs",
    "guard:phi:release": "node scripts/phi-pii-guard.mjs --scope release",
    "export": "node scripts/harness.mjs export",
    "export:reports": "node scripts/harness.mjs export-reports",
    "export:report-pdfs": "node scripts/harness.mjs export-report-pdfs",
    "clinical:cdisc-preflight": "node scripts/harness.mjs cdisc-preflight",
    "review:signoff": "node scripts/harness.mjs review-signoff",
    "evidence:index": "node scripts/harness.mjs evidence-index",
    "package:template": "node scripts/harness.mjs package-template",
    "package:source-template": "node scripts/source-template-package.mjs",
    "import:external-validation": "node scripts/import-external-validation.mjs",
    "build:harness": "node scripts/harness.mjs build",
    "phase3:preflight": "node scripts/phase3-preflight.mjs --allow-missing-credentials",
    "phase3:preflight:strict": "node scripts/phase3-preflight.mjs",
    "phase3:preflight:macos": "node scripts/phase3-preflight.mjs --platform macos --allow-missing-credentials",
    "phase3:preflight:windows": "node scripts/phase3-preflight.mjs --platform windows --allow-missing-credentials",
    "phase3:package": "node scripts/phase3-package.mjs",
    "phase3:package:macos": "node scripts/phase3-package.mjs --platform macos",
    "phase3:package:windows": "node scripts/phase3-package.mjs --platform windows",
    "local:audit": "node scripts/local-release-audit.mjs",
    "local:audit:macos": "node scripts/local-release-audit.mjs --platform macos",
    "local:audit:windows": "node scripts/local-release-audit.mjs --platform windows",
    "phase3:release-draft": "node scripts/github-release-draft.mjs",
    "build:release-local": "npm run verify && npm run clean:tauri-bundles && npm run tauri:build:app:no-sign && npm run phase3:preflight && npm run phase3:package && npm run verify:release && npm run local:audit:macos",
    "build:release-macos-local": "npm run verify && npm run clean:tauri-bundles && npm run tauri:build:app:no-sign && npm run phase3:preflight:macos && npm run phase3:package:macos && npm run verify:release && npm run local:audit:macos",
    "build:release-windows-local": "npm run verify && npm run clean:tauri-bundles && npm run tauri:build:windows:no-sign && npm run phase3:preflight:windows && npm run phase3:package:windows && npm run verify:release && npm run local:audit:windows",
    "tauri:dev": "tauri dev",
    "tauri:build:app": "tauri build --bundles app",
    "tauri:build:app:no-sign": "tauri build --bundles app --no-sign",
    "tauri:build:windows": "node scripts/tauri-build-windows.mjs",
    "tauri:build:windows:no-sign": "node scripts/tauri-build-windows.mjs --no-sign",
    "tauri:build:windows:msi": "node scripts/tauri-build-windows.mjs --bundles nsis,msi --no-sign",
    "tauri:build": "tauri build --bundles app",
    "tauri:build:dmg": "tauri build --bundles app,dmg",
    "tauri:build:dmg:no-sign": "tauri build --bundles app,dmg --no-sign"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.1",
    "lucide-react": "^1.20.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tauri-apps/cli": "2.11.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.1"
  }
}
